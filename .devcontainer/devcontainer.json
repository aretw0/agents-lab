{
  "name": "agents-lab-dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "runArgs": [
    "--memory=4g",
    "--cpus=4"
  ],
  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb"
  },
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false,
      "username": "vscode"
    }
  },
  "remoteUser": "vscode",
  "workspaceFolder": "/workspaces/agents-lab",
  "containerEnv": {
    "PI_CODING_AGENT_DIR": "/workspaces/agents-lab/.sandbox/pi-agent",
    "NPM_CONFIG_CACHE": "/home/vscode/.npm-cache",
    "NPM_CONFIG_PREFIX": "/home/vscode/.npm-global",
    "PNPM_HOME": "/home/vscode/.local/share/pnpm",
    "LANG": "pt_BR.UTF-8",
    "LC_ALL": "pt_BR.UTF-8",
    "LANGUAGE": "pt_BR:pt:en",
    "TERM": "xterm-256color",
    "COLORTERM": "truecolor"
  },
  "remoteEnv": {
    "PATH": "/home/vscode/.local/share/pnpm:/home/vscode/.npm-global/bin:/home/vscode/.local/bin:${containerEnv:PATH}",
    "LANG": "pt_BR.UTF-8",
    "LC_ALL": "pt_BR.UTF-8",
    "LANGUAGE": "pt_BR:pt:en",
    "COLORTERM": "truecolor"
  },
  "mounts": [
    "source=agents-lab-node-modules,target=/workspaces/agents-lab/node_modules,type=volume",
    "source=agents-lab-npm-cache,target=/home/vscode/.npm-cache,type=volume",
    "source=agents-lab-npm-global,target=/home/vscode/.npm-global,type=volume",
    "source=agents-lab-pnpm-store,target=/home/vscode/.local/share/pnpm/store,type=volume",
    "source=agents-lab-pi-home,target=/home/vscode/.pi,type=volume",
    "source=agents-lab-claude-home,target=/home/vscode/.claude,type=volume",
    "source=agents-lab-codex-home,target=/home/vscode/.codex,type=volume"
  ],
  "postCreateCommand": "bash .devcontainer/postCreate.sh",
  "postStartCommand": "bash .devcontainer/postStart.sh",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.env.linux": {
          "LANG": "pt_BR.UTF-8",
          "LC_ALL": "pt_BR.UTF-8",
          "LANGUAGE": "pt_BR:pt:en",
          "COLORTERM": "truecolor"
        }
      }
    }
  }
}

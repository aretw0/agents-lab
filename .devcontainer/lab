#!/usr/bin/env bash
set -euo pipefail

TARGET_USER="vscode"
PROJECT_DIR="/workspaces/agents-lab"

if [ "$#" -gt 0 ]; then
  TARGET_USER="$1"
  shift
fi

if [ "$#" -gt 0 ]; then
  PROJECT_DIR="$1"
  shift
fi

if ! id "$TARGET_USER" >/dev/null 2>&1 && id node >/dev/null 2>&1; then
  TARGET_USER="node"
fi

INIT_FILE="/home/${TARGET_USER}/.lab-init.sh"

cat > "$INIT_FILE" <<INIT
[ -f /home/${TARGET_USER}/.bashrc ] && . /home/${TARGET_USER}/.bashrc
export HOME=/home/${TARGET_USER}
export USER=${TARGET_USER}
export LANG=pt_BR.UTF-8
export LC_ALL=pt_BR.UTF-8
export LANGUAGE=pt_BR:pt:en
export TERM=\${TERM:-xterm-256color}
export COLORTERM=\${COLORTERM:-truecolor}
export NPM_CONFIG_CACHE=/home/${TARGET_USER}/.npm-cache
export NPM_CONFIG_PREFIX=/home/${TARGET_USER}/.npm-global
export PNPM_HOME=/home/${TARGET_USER}/.local/share/pnpm
export PI_CODING_AGENT_DIR=/workspaces/agents-lab/.sandbox/pi-agent
export PATH=/home/${TARGET_USER}/.local/share/pnpm:/home/${TARGET_USER}/.npm-global/bin:/home/${TARGET_USER}/.local/bin:\$PATH
cd "${PROJECT_DIR}"
INIT

chmod 644 "$INIT_FILE"

if [ "$#" -gt 0 ]; then
  command_text=$(printf "%q " "$@")
  exec su -s /bin/bash "$TARGET_USER" -- -lc ". '$INIT_FILE'; ${command_text}"
fi

exec su -s /bin/bash "$TARGET_USER" -- --init-file "$INIT_FILE"

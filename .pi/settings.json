{
  "packages": [
    "../packages/pi-stack",
    "../packages/git-skills",
    "../packages/web-skills",
    "../packages/pi-skills",
    "../packages/lab-skills",
    {
      "source": "npm:@aretw0/pi-stack",
      "extensions": [],
      "skills": [],
      "themes": []
    },
    {
      "source": "npm:@aretw0/git-skills",
      "extensions": [],
      "skills": [],
      "themes": []
    },
    {
      "source": "npm:@aretw0/web-skills",
      "extensions": [],
      "skills": [],
      "themes": []
    },
    {
      "source": "npm:@aretw0/pi-skills",
      "extensions": [],
      "skills": [],
      "themes": []
    },
    {
      "source": "npm:@aretw0/lab-skills",
      "extensions": [],
      "skills": [],
      "themes": []
    },
    {
      "source": "npm:@ifi/oh-pi-extensions",
      "extensions": [
        "!extensions/custom-footer.ts",
        "!extensions/usage-tracker.ts",
        "!extensions/usage-tracker-providers.ts"
      ],
      "skills": [],
      "themes": []
    }
  ],
  "piStack": {
    "monitorProviderPatch": {
      "classifierThinking": "off",
      "classifierModelByProvider": {
        "github-copilot": "github-copilot/claude-haiku-4.5",
        "openai-codex": "openai-codex/gpt-5.4-mini"
      },
      "hedgeConversationHistory": false
    },
    "colonyPilot": {
      "preflight": {
        "enabled": true,
        "enforceOnAntColonyTool": true,
        "requiredExecutables": ["node", "git"]
      },
      "budgetPolicy": {
        "enabled": true,
        "enforceOnAntColonyTool": true,
        "requireMaxCost": true,
        "autoInjectMaxCost": true,
        "defaultMaxCostUsd": 2,
        "hardCapUsd": 20,
        "minMaxCostUsd": 0.05,
        "enforceProviderBudgetBlock": true,
        "providerBudgetLookbackDays": 30,
        "allowProviderBudgetOverride": true,
        "providerBudgetOverrideToken": "budget-override:"
      },
      "projectTaskSync": {
        "enabled": true,
        "createOnLaunch": true,
        "trackProgress": true,
        "markTerminalState": true,
        "taskIdPrefix": "colony",
        "requireHumanClose": true,
        "maxNoteLines": 20
      },
      "deliveryPolicy": {
        "enabled": true,
        "mode": "apply-to-branch",
        "requireWorkspaceReport": true,
        "requireTaskSummary": true,
        "requireFileInventory": true,
        "requireValidationCommandLog": true,
        "blockOnMissingEvidence": true
      }
    },
    "guardrailsCore": {
      "providerBudgetGovernor": {
        "enabled": true,
        "lookbackDays": 30,
        "allowOverride": true,
        "overrideToken": "budget-override:",
        "recoveryCommands": ["doctor", "quota-visibility", "model", "login"]
      }
    },
    "quotaVisibility": {
      "defaultDays": 30,
      "providerBudgets": {
        "github-copilot": {
          "owner": "shared-github-account",
          "period": "monthly",
          "unit": "tokens-cost",
          "monthlyQuotaTokens": 650000000,
          "monthlyQuotaCostUsd": 40,
          "warnPct": 75,
          "hardPct": 100
        },
        "openai-codex": {
          "owner": "shared-portfolio",
          "period": "monthly",
          "unit": "tokens-cost",
          "monthlyQuotaTokens": 600000000,
          "monthlyQuotaCostUsd": 180,
          "warnPct": 70,
          "hardPct": 95
        },
        "google-antigravity": {
          "owner": "shared-portfolio",
          "period": "monthly",
          "unit": "tokens-cost",
          "monthlyQuotaTokens": 300000000,
          "monthlyQuotaCostUsd": 60,
          "warnPct": 80,
          "hardPct": 100
        },
        "google-gemini-cli": {
          "owner": "shared-portfolio",
          "period": "monthly",
          "unit": "tokens-cost",
          "monthlyQuotaTokens": 300000000,
          "monthlyQuotaCostUsd": 60,
          "warnPct": 80,
          "hardPct": 100
        }
      },
      "routeModelRefs": {
        "openai-codex": "openai-codex/gpt-5.3-codex",
        "github-copilot": "github-copilot/claude-sonnet-4.6",
        "google-antigravity": "google-antigravity/gemini-3.1-pro-high",
        "google-gemini-cli": "google-gemini-cli/gemini-3.1-pro-preview"
      }
    }
  }
}

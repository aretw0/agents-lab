{
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.3-codex",
  "packages": [
    {
      "source": "../packages/pi-stack",
      "extensions": [
        "!extensions/guardrails-agent-run.ts",
        "!extensions/guardrails-ops-calibration.ts",
        "!extensions/guardrails-unattended-continuation.ts",
        "!extensions/guardrails-background-process.ts",
        "!extensions/guardrails-core-extended-surfaces.ts",
        "!extensions/context-watchdog-surfaces.ts",
        "!extensions/web-session-gateway.ts",
        "!extensions/quota-panel.ts",
        "!extensions/quota-alerts.ts",
        "!extensions/provider-readiness.ts",
        "!extensions/subagent-readiness.ts",
        "!extensions/session-analytics.ts",
        "!extensions/handoff-advisor.ts",
        "!extensions/monitor-provider-patch.ts",
        "!extensions/monitor-sovereign.ts",
        "!extensions/monitor-summary.ts",
        "!extensions/stack-sovereignty.ts",
        "!extensions/governance-profiles.ts",
        "!extensions/scheduler-governance.ts",
        "!extensions/machine-maintenance.ts"
      ]
    },
    "../packages/git-skills",
    "../packages/web-skills",
    "../packages/pi-skills",
    "../packages/lab-skills",
    {
      "source": "npm:@ifi/oh-pi-extensions",
      "extensions": [
        "!extensions/answer.ts",
        "!extensions/auto-session-name.ts",
        "!extensions/auto-update.ts",
        "!extensions/btw.ts",
        "!extensions/compact-header.ts",
        "!extensions/custom-footer.ts",
        "!extensions/external-editor.ts",
        "!extensions/git-guard.ts",
        "!extensions/scheduler.ts",
        "!extensions/tool-metadata.ts",
        "!extensions/usage-tracker.ts",
        "!extensions/usage-tracker-providers.ts",
        "!extensions/safe-guard.ts",
        "!extensions/bg-process.ts",
        "!extensions/worktree.ts"
      ],
      "skills": [],
      "themes": []
    }
  ],
  "piStack": {
    "monitorProviderPatch": {
      "classifierThinking": "off",
      "hedgeWhen": "has_bash",
      "hedgeIncludeProjectContext": false,
      "hedgeConversationHistory": false,
      "classifierModelByProvider": {
        "openai-codex": "openai-codex/gpt-5.4-mini",
        "dashscope": "dashscope/qwen3.6-flash"
      }
    },
    "colonyPilot": {
      "preflight": {
        "enabled": true,
        "enforceOnAntColonyTool": true,
        "requiredExecutables": [
          "node",
          "git"
        ]
      },
      "modelPolicy": {
        "enabled": true,
        "allowMixedProviders": false,
        "allowedProviders": [],
        "modelGateEnabled": false,
        "gatedModelRefs": [],
        "gatedModelGoalTriggers": [
          "planning recovery",
          "scout burst"
        ],
        "gatedModelScoutOnlyTrigger": "scout burst"
      },
      "budgetPolicy": {
        "enabled": true,
        "enforceOnAntColonyTool": true,
        "requireMaxCost": true,
        "autoInjectMaxCost": true,
        "defaultMaxCostUsd": 0.5,
        "hardCapUsd": 60,
        "minMaxCostUsd": 0.05,
        "enforceProviderBudgetBlock": true,
        "providerBudgetLookbackDays": 30,
        "allowProviderBudgetOverride": true,
        "providerBudgetOverrideToken": "budget-override:"
      },
      "projectTaskSync": {
        "enabled": true,
        "createOnLaunch": false,
        "trackProgress": false,
        "markTerminalState": true,
        "taskIdPrefix": "colony",
        "requireHumanClose": true,
        "maxNoteLines": 20
      },
      "deliveryPolicy": {
        "enabled": true,
        "mode": "report-only",
        "requireWorkspaceReport": true,
        "requireTaskSummary": true,
        "requireFileInventory": true,
        "requireValidationCommandLog": true,
        "blockOnMissingEvidence": true
      },
      "outputPolicy": {
        "compactLargeJson": true,
        "maxInlineJsonChars": 1200
      },
      "candidateRetention": {
        "enabled": true,
        "maxEntries": 40,
        "maxAgeDays": 14
      }
    },
    "guardrailsCore": {
      "surfaces": {
        "enabled": false
      },
      "lineBudget": {
        "roots": [
          "packages/pi-stack"
        ],
        "ignoredDirs": [
          ".cache",
          ".pi-lens",
          "_site",
          "coverage",
          "dist",
          "node_modules"
        ],
        "extensions": [
          ".ts"
        ],
        "ignoreDeclarationFiles": true,
        "thresholds": {
          "watch": 1000,
          "extract": 1400,
          "critical": 2000
        }
      },
      "providerBudgetGovernor": {
        "enabled": true,
        "lookbackDays": 30,
        "allowOverride": true,
        "overrideToken": "budget-override:",
        "recoveryCommands": [
          "doctor",
          "quota-visibility",
          "model",
          "login"
        ]
      },
      "longRunIntentQueue": {
        "enabled": false,
        "autoDrainOnIdle": false
      }
    },
    "contextWatchdog": {
      "enabled": true,
      "checkpointPct": 55,
      "compactPct": 65,
      "cooldownMs": 600000,
      "notify": true,
      "modelSteeringFromLevel": "compact",
      "userNotifyFromLevel": "compact",
      "status": true,
      "autoCheckpoint": true,
      "autoCompact": true,
      "autoCompactCooldownMs": 1200000,
      "autoCompactRequireIdle": true,
      "autoResumeAfterCompact": true,
      "autoResumeCooldownMs": 30000,
      "handoffFreshMaxAgeMs": 1800000
    },
    "customFooter": {
      "contextPressure": {
        "byProviderModel": {
          "github-copilot/gpt-5.3-codex": {
            "warningPct": 45,
            "errorPct": 65
          }
        }
      }
    },
    "quotaVisibility": {
      "defaultDays": 30,
      "providerBudgets": {
        "openai-codex": {
          "owner": "openai-pro",
          "period": "monthly",
          "unit": "tokens-cost",
          "monthlyQuotaTokens": 1200000000,
          "monthlyQuotaCostUsd": 500,
          "warnPct": 85,
          "hardPct": 98
        },
        "dashscope": {
          "owner": "alibaba-free-trial-local-cap",
          "period": "monthly",
          "unit": "tokens-cost",
          "monthlyQuotaTokens": 250000,
          "monthlyQuotaCostUsd": 0.01,
          "warnPct": 70,
          "hardPct": 90
        },
        "openai-codex/gpt-5.3-codex-spark": {
          "owner": "openai-pro-spark-weekly-window",
          "period": "weekly",
          "unit": "requests",
          "model": "gpt-5.3-codex-spark",
          "weeklyQuotaRequests": 100,
          "warnPct": 80,
          "hardPct": 100
        }
      },
      "routeModelRefs": {
        "openai-codex": "openai-codex/gpt-5.3-codex",
        "dashscope": "dashscope/qwen3.6-flash"
      }
    },
    "quotaPanel": {
      "mode": "on"
    },
    "colonyPanel": {
      "mode": "auto",
      "autoOpenCountThreshold": 4,
      "maxVisibleColonies": 8
    },
    "schedulerGovernance": {
      "enabled": true,
      "policy": "observe",
      "requireTextConfirmation": true
    },
    "webSessionGateway": {
      "mode": "local"
    },
    "governanceProfile": {
      "active": "conservative"
    },
    "machineMaintenance": {
      "diskWarnFreeMb": 1024,
      "diskPauseFreeMb": 768,
      "diskBlockFreeMb": 512
    }
  }
}

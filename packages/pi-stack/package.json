{
  "name": "@aretw0/pi-stack",
  "version": "0.3.4",
  "description": "Meta-pacote que instala a stack curada de extensões pi do agents-lab — cada pacote individualmente",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "pi-package"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aretw0/agents-lab.git",
    "directory": "packages/pi-stack"
  },
  "bin": {
    "pi-stack": "install.mjs"
  },
  "files": [
    "install.mjs",
    "package-list.mjs",
    "extensions",
    "themes",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./extensions/monitor-provider-patch.ts",
      "./extensions/environment-doctor.ts",
      "./extensions/read-guard.ts"
    ],
    "themes": [
      "./themes"
    ]
  }
}

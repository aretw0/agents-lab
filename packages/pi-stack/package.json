{
  "name": "@aretw0/pi-stack",
  "version": "0.3.6",
  "description": "Meta-pacote que instala a stack curada de extens\u00f5es pi do agents-lab \u2014 cada pacote individualmente",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "pi-package"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aretw0/agents-lab.git",
    "directory": "packages/pi-stack"
  },
  "bin": {
    "pi-stack": "install.mjs"
  },
  "files": [
    "install.mjs",
    "package-list.mjs",
    "extensions",
    "themes",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./extensions/monitor-provider-patch.ts",
      "./extensions/environment-doctor.ts",
      "./extensions/read-guard.ts"
    ],
    "themes": [
      "./themes"
    ]
  },
  "devDependencies": {
    "mitsupi": "*",
    "pi-lens": "*",
    "pi-web-access": "*",
    "@davidorex/pi-project-workflows": "*",
    "@ifi/oh-pi-skills": "*",
    "@ifi/oh-pi-themes": "*",
    "@ifi/oh-pi-extensions": "*",
    "@ifi/oh-pi-ant-colony": "*",
    "@ifi/pi-extension-subagents": "*",
    "@ifi/pi-plan": "*",
    "@ifi/pi-spec": "*",
    "@ifi/pi-web-remote": "*"
  }
}
